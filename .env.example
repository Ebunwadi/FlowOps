# PostgreSQL (postgres service)
POSTGRES_VERSION=16-alpine
POSTGRES_USER=flowops
POSTGRES_PASSWORD=flowops
POSTGRES_DB=flowops
POSTGRES_PORT=5432

# Keycloak (keycloak service)
KEYCLOAK_VERSION=26.0.7
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=flowops

# API (api service)
NODE_ENV=development
PORT=5000
API_PREFIX=/api
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173

# Web (web service)
VITE_API_BASE_URL=http://localhost:5000/api
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=flowops
VITE_KEYCLOAK_CLIENT_ID=flowops-web

# Local API development (flowops-api/.env) — use localhost as the host:
# DATABASE_URL=postgresql://flowops:flowops@localhost:5432/flowops?schema=public
