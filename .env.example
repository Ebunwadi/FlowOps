# PostgreSQL (postgres service)
POSTGRES_VERSION=16-alpine
POSTGRES_USER=flowops
POSTGRES_PASSWORD=flowops
POSTGRES_DB=flowops
POSTGRES_PORT=5432

# Adminer (adminer service — web UI for PostgreSQL)
ADMINER_VERSION=4.8.1
ADMINER_PORT=8081

# Keycloak (keycloak service)
KEYCLOAK_VERSION=26.0.7
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=flowops

# API (api service)
NODE_ENV=development
PORT=5000
API_PREFIX=/api
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173
SEQ_SERVER_URL=http://localhost:5341
KEYCLOAK_ISSUER=http://localhost:8080/realms/flowops
KEYCLOAK_CLIENT_ID=flowops-web
# KEYCLOAK_JWKS_URI=       # Optional — defaults to {KEYCLOAK_ISSUER}/protocol/openid-connect/certs
# In Docker Compose the API uses http://keycloak:8080/... for JWKS fetch (see docker-compose.yml).
# SEQ_API_KEY=           # Optional — set when Seq ingestion authentication is enabled

# Seq (seq service)
SEQ_VERSION=2024.3
SEQ_PORT=5341

# Redis (redis service — BullMQ job queues)
REDIS_VERSION=7-alpine
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Web (web service)
VITE_API_BASE_URL=http://localhost:5000/api
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=flowops
VITE_KEYCLOAK_CLIENT_ID=flowops-web
VITE_CLIENT_LOGGING=true

# Local API development (flowops-api/.env) — use localhost as the host:
# DATABASE_URL=postgresql://flowops:flowops@localhost:5432/flowops?schema=public
