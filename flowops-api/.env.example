NODE_ENV=development
PORT=5000
API_PREFIX=/api
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173
DATABASE_URL=postgresql://flowops:flowops@localhost:5432/flowops?schema=public
SEQ_SERVER_URL=http://localhost:5341
KEYCLOAK_ISSUER=http://localhost:8080/realms/flowops
KEYCLOAK_CLIENT_ID=flowops-web
REDIS_URL=redis://localhost:6379

# When using Docker Compose, database, Seq, and Keycloak settings live in the repo root .env file.
# Copy the root .env.example to .env before running docker compose up.
