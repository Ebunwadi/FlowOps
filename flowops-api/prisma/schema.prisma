generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Local application profile linked to a Keycloak identity (auth is external).
/// OrganisationMember relation will be added in Sprint 3.
model User {
  id             String   @id @default(uuid())
  keycloakUserId String   @unique
  email          String   @unique
  firstName      String?
  lastName       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("users")
}
