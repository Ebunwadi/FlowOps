generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Local application profile linked to a Keycloak identity (auth is external).
model User {
  id             String   @id @default(uuid())
  keycloakUserId String   @unique
  email          String   @unique
  firstName      String?
  lastName       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organisationMemberships OrganisationMember[]
  createdOrganisations    Organisation[]       @relation("CreatedOrganisations")
  createdWorkflowTemplates WorkflowTemplate[]  @relation("CreatedWorkflowTemplates")
  workflowRequests        WorkflowRequest[]
  approvals               Approval[]
  comments                Comment[]

  @@map("users")
}

/// Tenant workspace; all workflow and membership data is scoped to an organisation.
model Organisation {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User                 @relation("CreatedOrganisations", fields: [createdById], references: [id])
  members   OrganisationMember[]
  roles     Role[]
  workflowTemplates WorkflowTemplate[]
  workflowRequests  WorkflowRequest[]

  @@index([createdById])
  @@map("organisations")
}

/// Links a FlowOps user to an organisation with an assigned role.
model OrganisationMember {
  id             String           @id @default(uuid())
  userId         String
  organisationId String
  roleId         String
  status         MembershipStatus @default(ACTIVE)
  joinedAt       DateTime         @default(now())

  user         User         @relation(fields: [userId], references: [id])
  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])

  @@unique([userId, organisationId])
  @@index([organisationId])
  @@index([roleId])
  @@map("organisation_members")
}

/// Application role — org-scoped custom roles or global system roles (organisationId null).
model Role {
  id             String   @id @default(uuid())
  organisationId String?
  name           String
  description    String?
  isSystemRole   Boolean  @default(false)
  createdAt      DateTime @default(now())

  organisation Organisation?        @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  members      OrganisationMember[]
  permissions  RolePermission[]
  approvalSteps WorkflowStep[]

  @@unique([organisationId, name])
  @@map("roles")
}

/// Fine-grained capability key checked by RBAC middleware (e.g. manage_users, approve_requests).
model Permission {
  id          String @id @default(uuid())
  key         String @unique
  description String

  roles RolePermission[]

  @@map("permissions")
}

/// Many-to-many join between roles and permissions.
model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum WorkflowTemplateStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum WorkflowFieldType {
  SHORT_TEXT
  LONG_TEXT
  NUMBER
  DATE
  DROPDOWN
  CHECKBOX
  RADIO
  FILE_UPLOAD
}

enum WorkflowRequestStatus {
  DRAFT
  SUBMITTED
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CANCELLED
  CHANGES_REQUESTED
}

enum ApprovalDecision {
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

/// Org-scoped workflow definition with dynamic form fields and approval steps.
model WorkflowTemplate {
  id             String                 @id @default(uuid())
  organisationId String
  name           String
  description    String?
  category       String?
  status         WorkflowTemplateStatus @default(DRAFT)
  isActive       Boolean                @default(false)
  createdById    String
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  organisation Organisation    @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  createdBy    User            @relation("CreatedWorkflowTemplates", fields: [createdById], references: [id])
  fields       WorkflowField[]
  steps        WorkflowStep[]
  requests     WorkflowRequest[]

  @@unique([organisationId, name])
  @@index([organisationId])
  @@index([createdById])
  @@map("workflow_templates")
}

/// Configurable input field on a workflow template submission form.
model WorkflowField {
  id                 String            @id @default(uuid())
  workflowTemplateId String
  label              String
  fieldKey           String
  fieldType          WorkflowFieldType
  helpText           String?
  placeholder        String?
  isRequired         Boolean           @default(false)
  options            Json?
  validationRules    Json?
  fieldOrder         Int
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  workflowTemplate WorkflowTemplate @relation(fields: [workflowTemplateId], references: [id], onDelete: Cascade)
  requestValues    WorkflowRequestValue[]

  @@unique([workflowTemplateId, fieldKey])
  @@index([workflowTemplateId])
  @@map("workflow_fields")
}

/// Ordered approval step assigned to an organisation role on a workflow template.
model WorkflowStep {
  id                 String   @id @default(uuid())
  workflowTemplateId String
  name               String
  description        String?
  stepOrder          Int
  approverRoleId     String
  slaHours           Int?
  allowDelegation    Boolean  @default(false)
  condition          Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workflowTemplate WorkflowTemplate @relation(fields: [workflowTemplateId], references: [id], onDelete: Cascade)
  approverRole     Role             @relation(fields: [approverRoleId], references: [id])
  currentRequests  WorkflowRequest[]
  approvals        Approval[]

  @@unique([workflowTemplateId, stepOrder])
  @@index([workflowTemplateId])
  @@index([approverRoleId])
  @@map("workflow_steps")
}

/// A submitted instance of a workflow template; an actual request moving through approvals.
model WorkflowRequest {
  id                 String                @id @default(uuid())
  organisationId     String
  workflowTemplateId String
  requesterId        String
  currentStepId      String?
  status             WorkflowRequestStatus @default(DRAFT)
  title              String?
  submittedAt        DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  organisation     Organisation           @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  workflowTemplate WorkflowTemplate        @relation(fields: [workflowTemplateId], references: [id])
  requester        User                    @relation(fields: [requesterId], references: [id])
  currentStep      WorkflowStep?           @relation(fields: [currentStepId], references: [id])
  values           WorkflowRequestValue[]
  approvals        Approval[]
  comments         Comment[]

  @@index([organisationId])
  @@index([workflowTemplateId])
  @@index([requesterId])
  @@index([currentStepId])
  @@index([status])
  @@map("workflow_requests")
}

/// A submitted value for a single workflow field on a workflow request.
model WorkflowRequestValue {
  id                String   @id @default(uuid())
  workflowRequestId String
  workflowFieldId   String
  value             Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workflowRequest WorkflowRequest @relation(fields: [workflowRequestId], references: [id], onDelete: Cascade)
  workflowField   WorkflowField   @relation(fields: [workflowFieldId], references: [id])

  @@unique([workflowRequestId, workflowFieldId])
  @@index([workflowRequestId])
  @@index([workflowFieldId])
  @@map("workflow_request_values")
}

/// An approval decision recorded when an approver acts on a workflow request step.
model Approval {
  id                String           @id @default(uuid())
  workflowRequestId String
  workflowStepId    String
  approverId        String
  decision          ApprovalDecision
  comment           String?
  decidedAt         DateTime         @default(now())
  createdAt         DateTime         @default(now())

  workflowRequest WorkflowRequest @relation(fields: [workflowRequestId], references: [id], onDelete: Cascade)
  workflowStep    WorkflowStep    @relation(fields: [workflowStepId], references: [id])
  approver        User            @relation(fields: [approverId], references: [id])

  @@index([workflowRequestId])
  @@index([workflowStepId])
  @@index([approverId])
  @@map("approvals")
}

/// A comment left on a workflow request by the requester or an involved approver.
model Comment {
  id                String   @id @default(uuid())
  workflowRequestId String
  authorId          String
  content           String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workflowRequest WorkflowRequest @relation(fields: [workflowRequestId], references: [id], onDelete: Cascade)
  author          User            @relation(fields: [authorId], references: [id])

  @@index([workflowRequestId])
  @@index([authorId])
  @@map("comments")
}
