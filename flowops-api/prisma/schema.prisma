generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Local application profile linked to a Keycloak identity (auth is external).
model User {
  id             String   @id @default(uuid())
  keycloakUserId String   @unique
  email          String   @unique
  firstName      String?
  lastName       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organisationMemberships OrganisationMember[]
  createdOrganisations    Organisation[]       @relation("CreatedOrganisations")
  createdWorkflowTemplates WorkflowTemplate[]  @relation("CreatedWorkflowTemplates")

  @@map("users")
}

/// Tenant workspace; all workflow and membership data is scoped to an organisation.
model Organisation {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User                 @relation("CreatedOrganisations", fields: [createdById], references: [id])
  members   OrganisationMember[]
  roles     Role[]
  workflowTemplates WorkflowTemplate[]

  @@index([createdById])
  @@map("organisations")
}

/// Links a FlowOps user to an organisation with an assigned role.
model OrganisationMember {
  id             String           @id @default(uuid())
  userId         String
  organisationId String
  roleId         String
  status         MembershipStatus @default(ACTIVE)
  joinedAt       DateTime         @default(now())

  user         User         @relation(fields: [userId], references: [id])
  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])

  @@unique([userId, organisationId])
  @@index([organisationId])
  @@index([roleId])
  @@map("organisation_members")
}

/// Application role — org-scoped custom roles or global system roles (organisationId null).
model Role {
  id             String   @id @default(uuid())
  organisationId String?
  name           String
  description    String?
  isSystemRole   Boolean  @default(false)
  createdAt      DateTime @default(now())

  organisation Organisation?        @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  members      OrganisationMember[]
  permissions  RolePermission[]
  approvalSteps WorkflowStep[]

  @@unique([organisationId, name])
  @@map("roles")
}

/// Fine-grained capability key checked by RBAC middleware (e.g. manage_users, approve_requests).
model Permission {
  id          String @id @default(uuid())
  key         String @unique
  description String

  roles RolePermission[]

  @@map("permissions")
}

/// Many-to-many join between roles and permissions.
model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum WorkflowTemplateStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum WorkflowFieldType {
  SHORT_TEXT
  LONG_TEXT
  NUMBER
  DATE
  DROPDOWN
  CHECKBOX
  RADIO
  FILE_UPLOAD
}

/// Org-scoped workflow definition with dynamic form fields and approval steps.
model WorkflowTemplate {
  id             String                 @id @default(uuid())
  organisationId String
  name           String
  description    String?
  category       String?
  status         WorkflowTemplateStatus @default(DRAFT)
  isActive       Boolean                @default(false)
  createdById    String
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  organisation Organisation    @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  createdBy    User            @relation("CreatedWorkflowTemplates", fields: [createdById], references: [id])
  fields       WorkflowField[]
  steps        WorkflowStep[]

  @@unique([organisationId, name])
  @@index([organisationId])
  @@index([createdById])
  @@map("workflow_templates")
}

/// Configurable input field on a workflow template submission form.
model WorkflowField {
  id                 String            @id @default(uuid())
  workflowTemplateId String
  label              String
  fieldKey           String
  fieldType          WorkflowFieldType
  helpText           String?
  placeholder        String?
  isRequired         Boolean           @default(false)
  options            Json?
  validationRules    Json?
  fieldOrder         Int
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  workflowTemplate WorkflowTemplate @relation(fields: [workflowTemplateId], references: [id], onDelete: Cascade)

  @@unique([workflowTemplateId, fieldKey])
  @@index([workflowTemplateId])
  @@map("workflow_fields")
}

/// Ordered approval step assigned to an organisation role on a workflow template.
model WorkflowStep {
  id                 String   @id @default(uuid())
  workflowTemplateId String
  name               String
  description        String?
  stepOrder          Int
  approverRoleId     String
  slaHours           Int?
  allowDelegation    Boolean  @default(false)
  condition          Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workflowTemplate WorkflowTemplate @relation(fields: [workflowTemplateId], references: [id], onDelete: Cascade)
  approverRole     Role             @relation(fields: [approverRoleId], references: [id])

  @@unique([workflowTemplateId, stepOrder])
  @@index([workflowTemplateId])
  @@index([approverRoleId])
  @@map("workflow_steps")
}
